generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model card_infos {
  card_info_id         String   @id @db.VarChar(50)
  client_id            Int
  card_number          String   @db.VarChar(20)
  card_expiration_date DateTime @db.Date
  cvc_number           String   @db.VarChar(4)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  clients              clients  @relation(fields: [client_id], references: [client_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([client_id], map: "idx_card_infos_client_id")
}

model clients {
  client_id       Int               @id @default(autoincrement())
  email           String            @unique @db.VarChar(255)
  password        String            @db.VarChar(255)
  name            String?           @db.VarChar(255)
  institute       String?           @db.VarChar(255)
  date_of_birth   DateTime?         @db.Date
  country         String?           @db.VarChar(100)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  image_url       String?           @db.VarChar
  auth_provider   String?           @default("'LOCAL'") @db.VarChar
  card_infos      card_infos[]
  course_progress course_progress[]
  enrollments     enrollments[]
  payments        payments[]
  reviews         reviews[]

  @@index([email], map: "idx_clients_email")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model course_progress {
  progress_id           String          @id @db.VarChar(50)
  client_id             Int
  course_id             String          @db.VarChar(50)
  overall_status        progress_status @default(NOT_STARTED)
  completion_percentage Decimal         @default(0.00) @db.Decimal(5, 2)
  time_spent_seconds    Int             @default(0)
  started_at            DateTime?       @db.Timestamptz(6)
  completed_at          DateTime?       @db.Timestamptz(6)
  clients               clients         @relation(fields: [client_id], references: [client_id], onDelete: Cascade, onUpdate: NoAction)
  courses               courses         @relation(fields: [course_id], references: [course_id], onUpdate: NoAction)

  @@unique([client_id, course_id])
  @@index([client_id], map: "idx_course_progress_client_id")
  @@index([course_id], map: "idx_course_progress_course_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model courses {
  course_id             String            @id @db.VarChar(50)
  title                 String            @db.VarChar(255)
  partner_id            String            @db.VarChar(50)
  description           String?
  credits               Int               @default(0) @db.SmallInt
  language              String            @default("English") @db.VarChar(50)
  price                 Decimal           @default(0.00) @db.Decimal(10, 2)
  difficulty            difficulty_level  @default(Beginner)
  created_at            DateTime          @default(now()) @db.Timestamptz(6)
  updated_at            DateTime          @default(now()) @db.Timestamptz(6)
  course_tagline        String?           @db.VarChar(255)
  course_duration_hours Decimal?          @db.Decimal(5, 2)
  skills                Json?             @default("[]")
  learning_outcomes     Json?             @default("[]")
  curriculum            Json?             @default("[]")
  image_url             String?           @db.VarChar
  course_progress       course_progress[]
  partners              partners          @relation(fields: [partner_id], references: [partner_id], onUpdate: NoAction)
  enrollments           enrollments[]
  payments              payments[]
  reviews               reviews[]

  @@index([description(ops: raw("gin_trgm_ops"))], map: "idx_courses_description_trgm", type: Gin)
  @@index([difficulty], map: "idx_courses_difficulty")
  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_courses_title_trgm", type: Gin)
}

model enrollments {
  enrollment_id String            @id @db.VarChar(50)
  client_id     Int
  course_id     String            @db.VarChar(50)
  status        enrollment_status @default(ACTIVE)
  enrolled_at   DateTime          @default(now()) @db.Timestamptz(6)
  clients       clients           @relation(fields: [client_id], references: [client_id], onUpdate: NoAction)
  courses       courses           @relation(fields: [course_id], references: [course_id], onUpdate: NoAction)

  @@unique([client_id, course_id])
  @@index([client_id], map: "idx_enrollments_client_id")
  @@index([course_id], map: "idx_enrollments_course_id")
  @@index([status], map: "idx_enrollments_status")
}

model partners {
  partner_id            String    @id @db.VarChar(50)
  name                  String    @db.VarChar(255)
  institute             String?   @db.VarChar(255)
  digital_signature_url String?
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  instructor_title      String?   @db.VarChar(255)
  instructor_image_url  String?
  instructor_bio        String?
  courses               courses[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  transaction_id          String           @id @db.VarChar(50)
  provider_transaction_id String?          @unique @db.VarChar(100)
  client_id               Int?
  course_id               String?          @db.VarChar(50)
  amount                  Decimal          @db.Decimal(12, 2)
  fee                     Decimal          @default(0.00) @db.Decimal(10, 2)
  currency                String           @default("BDT") @db.VarChar(10)
  provider                payment_provider
  account_identifier      String           @db.VarChar(100)
  status                  payment_status   @default(PENDING)
  transaction_type        transaction_type @default(PAYMENT)
  processed_at            DateTime         @default(now()) @db.Timestamptz(6)
  clients                 clients?         @relation(fields: [client_id], references: [client_id], onDelete: Restrict, onUpdate: NoAction)
  courses                 courses?         @relation(fields: [course_id], references: [course_id], onDelete: Restrict, onUpdate: NoAction)
  refunds                 refunds[]

  @@index([client_id], map: "idx_payments_client_id")
  @@index([course_id], map: "idx_payments_course_id")
  @@index([status], map: "idx_payments_status")
  @@index([provider_transaction_id], map: "idx_payments_providertrxid")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model refunds {
  refund_id               String   @id @db.VarChar(50)
  original_transaction_id String   @db.VarChar(50)
  amount_refunded         Decimal  @db.Decimal(12, 2)
  reason                  String?
  status                  String   @default("REFUNDED") @db.VarChar(20)
  processed_at            DateTime @default(now()) @db.Timestamptz(6)
  payments                payments @relation(fields: [original_transaction_id], references: [transaction_id], onUpdate: NoAction)

  @@index([original_transaction_id], map: "idx_refunds_transaction_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reviews {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  rating     Decimal  @db.Decimal
  comment    String
  client_id  Int
  course_id  String   @db.VarChar
  clients    clients  @relation(fields: [client_id], references: [client_id], onDelete: NoAction, onUpdate: NoAction)
  courses    courses  @relation(fields: [course_id], references: [course_id], onDelete: NoAction, onUpdate: NoAction)
}

enum difficulty_level {
  Beginner
  Intermediate
  Advanced
}

enum enrollment_status {
  ACTIVE
  PENDING
  DROPPED
}

enum payment_provider {
  BKASH
  NAGAD
  SSLCOMMERZ
  CREDIT_CARD
}

enum payment_status {
  COMPLETED
  PENDING
  FAILED
}

enum progress_status {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum transaction_type {
  PAYMENT
  REFUND
}
